{
  "name": "@zosmaai/gacli",
  "version": "1.1.0",
  "description": "Full-featured Google Analytics 4 CLI — Data API + Admin API, OAuth/SA auth, multiple output formats, MCP server. Ships native AI-assistant skill packages for Claude Code, Codex, Qwen, and Gemini CLIs.",
  "type": "module",
  "license": "MIT",
  "author": "Ion (Nalyk) Calmîș",
  "homepage": "https://opensource.yoda.digital/en/projects/gacli/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zosmaai/gacli.git"
  },
  "bugs": {
    "url": "https://github.com/nalyk/gacli/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "gacli": "dist/index.js"
  },
  "files": [
    "dist",
    "extensions",
    "README.md",
    "help.md",
    "LICENSE"
  ],
  "keywords": [
    "google-analytics",
    "ga4",
    "cli",
    "analytics",
    "data-api",
    "admin-api",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "codex",
    "gemini-cli",
    "qwen-code",
    "ai-agent",
    "agent-skills",
    "skill"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "verify:skills": "node scripts/verify-skills.mjs",
    "verify": "pnpm lint && pnpm type-check && pnpm test && pnpm verify:skills && pnpm build",
    "prepublishOnly": "pnpm verify",
    "publint": "pnpm dlx publint"
  },
  "dependencies": {
    "@google-analytics/admin": "^9.0.1",
    "@google-analytics/data": "^5.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "google-auth-library": "^9.14.0",
    "ora": "^9.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.5",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
